# ACOS 2.0 zero-cost AI policy
# OpenRouter is the primary external AI gateway for this project.
OPENROUTER_API_KEY=""

# Paid and automatic model routing is blocked by default.
# Keep this true in staging and production.
FREE_ONLY="true"

# Optional app URL used for self-referential links and callbacks.
APP_URL="MY_APP_URL"
PORT="3000"
NODE_ENV="development"

# Direct paid-provider credentials are intentionally disabled for this project.
# Do not configure these in staging or production unless the zero-cost policy changes.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
PERPLEXITY_API_KEY=""

# PostgreSQL Connection (optional ACOS 2.0 infrastructure)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/acos"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="acos"

# Redis Connection (optional ACOS 2.0 cache)
REDIS_URL="redis://localhost:6379"

# GitHub API Token (optional delivery engine)
# Required only for pushing sprint branches and opening PRs automatically.
GITHUB_TOKEN=""